{% extends 'base.html.twig' %}

{% block title %}Blog o turistike a zaujímavých miestach – {{ 'site_name'|trans }}{% endblock %}

{% block ogtags %}
    <meta name="description" content="Objavujte zaujímavé miesta, turistické a cykloturistické trasy na Slovensku a v Česku. Tipy, sprievodcovia a inšpirácia pre výlety do prírody.">
    <meta property="og:title" content="Blog o turistike a zaujímavých miestach – {{ 'site_name'|trans }}"/>
    <meta property="og:type" content="website"/>
    <meta property="og:url" content="{{ url('blog_index') }}"/>
    <meta property="og:description" content="Objavujte zaujímavé miesta, turistické a cykloturistické trasy na Slovensku a v Česku. Tipy, sprievodcovia a inšpirácia pre výlety do prírody."/>
    <meta property="og:site_name" content="{{ 'site_name'|trans }}"/>
    <link rel="canonical" href="{{ url('blog_index') }}"/>
{% endblock %}

{% block body %}
<div class="container my-5">
    <h1 class="mb-2">Blog</h1>
    <p class="text-muted mb-5">Zaujímavé miesta, turistické trasy a tipy na výlety do prírody.</p>

    {% if posts is empty %}
        <p class="text-muted">Zatiaľ žiadne príspevky.</p>
    {% else %}
        <div class="row g-4">
            {% for post in posts %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    {% if post.photos is defined and post.photos|length > 0 %}
                    <img src="{{ asset('uploads/photos/' ~ post.photos.first.path) }}"
                         class="card-img-top"
                         alt="{{ post.title }}"
                         style="height:200px;object-fit:cover;"
                         loading="lazy">
                    {% endif %}
                    <div class="card-body d-flex flex-column">
                        <h2 class="card-title h5">
                            <a href="{{ path('blog_show', {slug: post.slug}) }}" class="text-decoration-none stretched-link">
                                {{ post.title }}
                            </a>
                        </h2>
                        <p class="card-text text-muted flex-grow-1">{{ post.shortDescription }}</p>
                        {% if post.tags is not empty %}
                        <div class="mt-2" style="position:relative;z-index:1;">
                            {% for tag in post.tags %}
                            <a href="{{ path('blog_tag', {slug: tag.slug}) }}" class="badge bg-secondary me-1 text-decoration-none">{{ tag.name }}</a>
                            {% endfor %}
                        </div>
                        {% endif %}
                        <small class="text-muted mt-3 d-flex gap-3">
                            <span><i class="bi bi-calendar3"></i> {{ post.publishedAt ? post.publishedAt|date('d.m.Y') : '' }}</span>
                            {% set readingTime = (post.text|striptags|split(' ')|length / 200)|round %}
                            <span><i class="bi bi-clock"></i> {{ readingTime < 1 ? 1 : readingTime }} min čítania</span>
                        </small>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
