{% extends 'base.html.twig' %}

{% block title %}Blog o hubárstve – {{ 'site_name'|trans }}{% endblock %}

{% block ogtags %}
    <meta name="description" content="Čítajte zaujímavé články o turistike, bicyklovaní a zaujímavých miestach na Slovensku aj v Čechách.">
    <meta property="og:title" content="Blog – {{ 'site_name'|trans }}"/>
    <meta property="og:type" content="website"/>
    <meta property="og:url" content="{{ url('blog_index') }}"/>
    <meta property="og:description" content="Čítajte zaujímavé články o hubárstve, hubárskych lokalitách a tipoch na zber húb na Slovensku."/>
    <meta property="og:site_name" content="{{ 'site_name'|trans }}"/>
    <link rel="canonical" href="{{ url('blog_index') }}"/>
{% endblock %}

{% block body %}
<div class="container my-5">
    <h1 class="mb-2">Blog</h1>
    <p class="text-muted mb-5">Zaujímavé miesta, tipy a príbehy zo sveta hubárstva.</p>

    {% if posts is empty %}
        <p class="text-muted">Zatiaľ žiadne príspevky.</p>
    {% else %}
        <div class="row g-4">
            {% for post in posts %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    {% if post.photos is defined and post.photos|length > 0 %}
                    <img src="{{ asset('uploads/photos/' ~ post.photos.first.path) }}"
                         class="card-img-top"
                         alt="{{ post.title }}"
                         style="height:200px;object-fit:cover;"
                         loading="lazy">
                    {% endif %}
                    <div class="card-body d-flex flex-column">
                        <h2 class="card-title h5">
                            <a href="{{ path('blog_show', {slug: post.slug}) }}" class="text-decoration-none stretched-link">
                                {{ post.title }}
                            </a>
                        </h2>
                        <p class="card-text text-muted flex-grow-1">{{ post.shortDescription }}</p>
                        {% if post.tags is not empty %}
                        <div class="mt-2">
                            {% for tag in post.tags %}
                            <span class="badge bg-secondary me-1">{{ tag }}</span>
                            {% endfor %}
                        </div>
                        {% endif %}
                        <small class="text-muted mt-3">
                            <i class="bi bi-calendar3"></i>
                            {{ post.publishedAt ? post.publishedAt|date('d.m.Y') : '' }}
                        </small>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
