{% extends 'base.html.twig' %}

{% block title %}{{ post.title }} – {{ 'site_name'|trans }}{% endblock %}

{% block ogtags %}
    <meta name="description" content="{{ post.shortDescription }}">
    <meta property="og:title" content="{{ post.title }}"/>
    <meta property="og:type" content="article"/>
    <meta property="og:url" content="{{ url('blog_show', {slug: post.slug}) }}"/>
    <meta property="og:description" content="{{ post.shortDescription }}"/>
    <meta property="og:site_name" content="{{ 'site_name'|trans }}"/>
    {% if post.photos is defined and post.photos|length > 0 %}
    <meta property="og:image" content="{{ absolute_url(asset('uploads/photos/' ~ post.photos.first.path)) }}"/>
    <meta property="og:image:alt" content="{{ post.title }}"/>
    {% endif %}
    {% if post.publishedAt %}
    <meta property="article:published_time" content="{{ post.publishedAt|date('c') }}"/>
    {% endif %}
    {% for tag in post.tags %}
    <meta property="article:tag" content="{{ tag.name }}"/>
    {% endfor %}
    <link rel="canonical" href="{{ url('blog_show', {slug: post.slug}) }}"/>

    {# JSON-LD BlogPosting #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": {{ post.title|json_encode|raw }},
        "description": {{ post.shortDescription|json_encode|raw }},
        "url": {{ url('blog_show', {slug: post.slug})|json_encode|raw }},
        {% if post.publishedAt %}
        "datePublished": {{ post.publishedAt|date('c')|json_encode|raw }},
        {% endif %}
        "dateModified": {{ post.createdAt|date('c')|json_encode|raw }},
        {% if post.photos is defined and post.photos|length > 0 %}
        "image": {{ absolute_url(asset('uploads/photos/' ~ post.photos.first.path))|json_encode|raw }},
        {% endif %}
        "publisher": {
            "@type": "Organization",
            "name": {{ 'site_name'|trans|json_encode|raw }},
            "url": {{ url('app_home')|json_encode|raw }}
        },
        "keywords": {{ post.tags|map(t => t.name)|join(', ')|json_encode|raw }}
    }
    </script>

    {# JSON-LD BreadcrumbList #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            {
                "@type": "ListItem",
                "position": 1,
                "name": {{ 'site_name'|trans|json_encode|raw }},
                "item": {{ url('app_home')|json_encode|raw }}
            },
            {
                "@type": "ListItem",
                "position": 2,
                "name": "Blog",
                "item": {{ url('blog_index')|json_encode|raw }}
            }
            {% if post.tags is not empty %},
            {
                "@type": "ListItem",
                "position": 3,
                "name": {{ post.tags.first.name|json_encode|raw }},
                "item": {{ url('blog_tag', {slug: post.tags.first.slug})|json_encode|raw }}
            },
            {
                "@type": "ListItem",
                "position": 4,
                "name": {{ post.title|json_encode|raw }},
                "item": {{ url('blog_show', {slug: post.slug})|json_encode|raw }}
            }
            {% else %},
            {
                "@type": "ListItem",
                "position": 3,
                "name": {{ post.title|json_encode|raw }},
                "item": {{ url('blog_show', {slug: post.slug})|json_encode|raw }}
            }
            {% endif %}
        ]
    }
    </script>
{% endblock %}

{% block stylesheets %}
<style>
#reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 3px;
    background: linear-gradient(90deg, #198754, #20c997);
    z-index: 9999;
    transition: width 0.1s linear;
}
</style>
{% endblock %}

{% block body %}
<div id="reading-progress"></div>
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('blog_index') }}">Blog</a></li>
                    {% if post.tags is not empty %}
                    <li class="breadcrumb-item">
                        <a href="{{ path('blog_tag', {slug: post.tags.first.slug}) }}">{{ post.tags.first.name }}</a>
                    </li>
                    {% endif %}
                    <li class="breadcrumb-item active" aria-current="page">{{ post.title }}</li>
                </ol>
            </nav>

            {% if post.photos is defined and post.photos|length > 0 %}
            <img src="{{ asset('uploads/photos/' ~ post.photos.first.path) }}"
                 alt="{{ post.title }}"
                 class="img-fluid rounded mb-4 w-100"
                 style="max-height:450px;object-fit:cover;">
            {% endif %}

            <h1 class="mb-2">{{ post.title }}</h1>

            <div class="text-muted mb-4 d-flex align-items-center gap-3 flex-wrap">
                {% if post.publishedAt %}
                <span><i class="bi bi-calendar3"></i> {{ post.publishedAt|date('d.m.Y') }}</span>
                {% endif %}
                {% set readingTime = (post.text|striptags|split(' ')|length / 200)|round %}
                <span><i class="bi bi-clock"></i> {{ readingTime < 1 ? 1 : readingTime }} min čítania</span>
                {% if post.tags is not empty %}
                <span>
                    {% for tag in post.tags %}
                    <a href="{{ path('blog_tag', {slug: tag.slug}) }}" class="badge bg-secondary me-1 text-decoration-none">{{ tag.name }}</a>
                    {% endfor %}
                </span>
                {% endif %}
            </div>

            <p class="lead border-start border-3 ps-3 text-muted">{{ post.shortDescription }}</p>

            <div class="blog-content mt-4">
                {{ post.text|raw }}
            </div>

            {% if post.photos is defined and post.photos|length > 1 %}
            <div class="mt-5">
                <h3 class="h5 mb-3">Fotografie</h3>
                <div class="row g-2">
                    {% for photo in post.photos %}
                    <div class="col-6 col-md-4">
                        <img src="{{ asset('uploads/photos/' ~ photo.path) }}"
                             alt="{{ post.title }}"
                             class="img-fluid rounded"
                             loading="lazy">
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {% if related is defined and related|length > 0 %}
            <div class="mt-5 pt-4 border-top">
                <h3 class="h5 mb-3">Súvisiace články</h3>
                <div class="row g-3">
                    {% for rel in related %}
                    <div class="col-md-4">
                        <div class="card h-100 shadow-sm">
                            {% if rel.photos|length > 0 %}
                            <img src="{{ asset('uploads/photos/' ~ rel.photos.first.path) }}"
                                 class="card-img-top"
                                 alt="{{ rel.title }}"
                                 style="height:140px;object-fit:cover;"
                                 loading="lazy">
                            {% endif %}
                            <div class="card-body">
                                <h4 class="card-title h6">
                                    <a href="{{ path('blog_show', {slug: rel.slug}) }}" class="text-decoration-none stretched-link">
                                        {{ rel.title }}
                                    </a>
                                </h4>
                                <p class="card-text small text-muted">{{ rel.shortDescription|slice(0, 80) }}…</p>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            <div class="mt-5 pt-3 border-top">
                <a href="{{ path('blog_index') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Späť na blog
                </a>
            </div>

        </div>
    </div>
</div>
<script>
(function () {
    const bar = document.getElementById('reading-progress');
    const article = document.querySelector('.blog-content');
    if (!bar || !article) return;

    window.addEventListener('scroll', function () {
        const articleTop = article.getBoundingClientRect().top + window.scrollY;
        const articleBottom = articleTop + article.offsetHeight;
        const scrolled = window.scrollY + window.innerHeight;
        const percent = Math.min(100, Math.max(0,
            ((scrolled - articleTop) / (articleBottom - articleTop)) * 100
        ));
        bar.style.width = percent + '%';
    }, { passive: true });
})();
</script>
{% endblock %}