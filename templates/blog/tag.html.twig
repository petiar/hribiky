{% extends 'base.html.twig' %}

{% block title %}Články s tagom „{{ tag.name }}" – {{ 'site_name'|trans }}{% endblock %}

{% block ogtags %}
    <meta name="description" content="Všetky blogové články s tagom {{ tag.name }}.">
    <meta property="og:title" content="Články s tagom „{{ tag.name }}" – {{ 'site_name'|trans }}"/>
    <meta property="og:type" content="website"/>
    <meta property="og:url" content="{{ url('blog_tag', {slug: tag.slug}) }}"/>
    <link rel="canonical" href="{{ url('blog_tag', {slug: tag.slug}) }}"/>

    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            {
                "@type": "ListItem",
                "position": 1,
                "name": {{ 'site_name'|trans|json_encode|raw }},
                "item": {{ url('app_home')|json_encode|raw }}
            },
            {
                "@type": "ListItem",
                "position": 2,
                "name": "Blog",
                "item": {{ url('blog_index')|json_encode|raw }}
            },
            {
                "@type": "ListItem",
                "position": 3,
                "name": {{ tag.name|json_encode|raw }},
                "item": {{ url('blog_tag', {slug: tag.slug})|json_encode|raw }}
            }
        ]
    }
    </script>
{% endblock %}

{% block body %}
<div class="container my-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('blog_index') }}">Blog</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ tag.name }}</li>
        </ol>
    </nav>

    <h1 class="mb-2">Tag: <span class="badge bg-secondary">{{ tag.name }}</span></h1>
    <p class="text-muted mb-5">{{ posts|length }} {{ posts|length == 1 ? 'článok' : (posts|length < 5 ? 'články' : 'článkov') }} s týmto tagom.</p>

    {% if posts is empty %}
        <p class="text-muted">Žiadne články s týmto tagom.</p>
    {% else %}
        <div class="row g-4">
            {% for post in posts %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    {% if post.photos is defined and post.photos|length > 0 %}
                    <img src="{{ asset('uploads/photos/' ~ post.photos.first.path) }}"
                         class="card-img-top"
                         alt="{{ post.title }}"
                         style="height:200px;object-fit:cover;"
                         loading="lazy">
                    {% endif %}
                    <div class="card-body d-flex flex-column">
                        <h2 class="card-title h5">
                            <a href="{{ path('blog_show', {slug: post.slug}) }}" class="text-decoration-none stretched-link">
                                {{ post.title }}
                            </a>
                        </h2>
                        <p class="card-text text-muted flex-grow-1">{{ post.shortDescription }}</p>
                        {% if post.tags is not empty %}
                        <div class="mt-2" style="position:relative;z-index:1;">
                            {% for t in post.tags %}
                            <a href="{{ path('blog_tag', {slug: t.slug}) }}"
                               class="badge me-1 text-decoration-none {{ t.slug == tag.slug ? 'bg-primary' : 'bg-secondary' }}">{{ t.name }}</a>
                            {% endfor %}
                        </div>
                        {% endif %}
                        <small class="text-muted mt-3 d-flex gap-3">
                            <span><i class="bi bi-calendar3"></i> {{ post.publishedAt ? post.publishedAt|date('d.m.Y') : '' }}</span>
                            {% set readingTime = (post.text|striptags|split(' ')|length / 200)|round %}
                            <span><i class="bi bi-clock"></i> {{ readingTime < 1 ? 1 : readingTime }} min čítania</span>
                        </small>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}

    <div class="mt-5 pt-3 border-top">
        <a href="{{ path('blog_index') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Späť na blog
        </a>
    </div>
</div>
{% endblock %}