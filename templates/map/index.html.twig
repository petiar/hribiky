{% extends 'base.html.twig' %}

{% block title %}{{ 'site_name'|trans }}{% endblock %}

{% block navbarbrand %}{{ count }} {{ 'mushroom_count'|trans }}{% endblock %}

{% block ogtags %}
    <meta property="og:title" content="{{ 'site_name'|trans }}"/>
    <meta property="og:type" content="website"/>
    <meta property="og:url" content="{{ url('app_home') }}"/>
    <meta property="og:image" content="{{ absolute_url(asset('uploads/photos/' ~ randomRozcestnik.photos.0.path)) }}" />
    <meta property="og:description" content="{{ 'site_description'|trans }}"/>
    <meta property="og:site_name" content="{{ 'site_name'|trans }}"/>
{% endblock %}

{% block body %}
    <div class="container mt-3">
        <div id="map" style="height: 80vh;"></div>
    </div>

    {% include 'map/modal.html.twig' %}

{% endblock %}

{% block mapscripts %}
    <script src="https://unpkg.com/@googlemaps/markerclusterer/dist/index.min.js"></script>
    <script src="https://maps.googleapis.com/maps/api/js?key={{ google_maps_api_key }}&libraries=marker&v=weekly&language=sk"
            defer></script>
    <script>
        const hribiky = {{ mushrooms|raw }};
    </script>
{% endblock %}
