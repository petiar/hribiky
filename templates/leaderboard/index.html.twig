{% extends 'base.html.twig' %}

{% block title %}{{ 'leaderboard.title'|trans }}{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="d-flex align-items-center mb-4">
                    <h1 class="h3 mb-0 me-3">{{ 'leaderboard.heading'|trans }}</h1>
                    <span class="badge bg-success">{{ 'leaderboard.subheading'|trans }}</span>
                </div>

                {% if contributors is empty %}
                    <div class="alert alert-info">
                        {{ 'leaderboard.empty'|trans }}
                    </div>
                {% else %}
                    <ul class="list-group shadow-sm">
                        {% for user in contributors %}
                            {% set rank = loop.index %}

                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <div class="me-3 text-center" style="min-width: 2.5rem;">
                                        {% if rank == 1 %}
                                            <span class="fs-4">🥇</span>
                                        {% elseif rank == 2 %}
                                            <span class="fs-4">🥈</span>
                                        {% elseif rank == 3 %}
                                            <span class="fs-4">🥉</span>
                                        {% else %}
                                            <span class="text-muted fw-semibold">{{ rank }}.</span>
                                        {% endif %}
                                    </div>

                                    <div>
                                        <div class="fw-semibold">
                                            {{ user.name ?: 'leaderboard.unknown_user'|trans }}
                                            {% if user.hasRole is defined and user.hasRole('ROLE_RELIABLE') %}
                                                <span class="badge bg-warning text-dark ms-2">{{ 'leaderboard.reliable'|trans }}</span>
                                            {% endif %}
                                        </div>
                                        <div class="text-muted small">
                                            {{ 'leaderboard.count'|trans({'%count%': user.mushroomCount}) }}
                                            {% if user.commentCount %}
                                                · {{ 'leaderboard.comment_count'|trans({'%count%': user.commentCount}) }}
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>

                                <span class="badge bg-primary rounded-pill px-3 py-2">{{ user.score }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}

                <div class="text-muted small mt-3">
                    <p>{{ 'leaderboard.note1'|trans }}</p>
                    <p>{{ 'leaderboard.note2'|trans }}</p>
                </div>

            </div>
        </div>
    </div>
{% endblock %}

