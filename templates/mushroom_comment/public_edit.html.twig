{% extends 'base.html.twig' %}

{% block title %}Doplniť popis ku komentáru{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-md-10">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h1 class="h3 mb-4 text-center">{{ comment.mushroom.title }}</h1>

                        <div class="mb-4 text-center">
                            <p class="text-muted mb-0">
                                Komentár pridaný {{ comment.createdAt|date('d.m.Y H:i') }}
                            </p>
                        </div>

                        {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': ''}}) }}
                        <div class="mb-4">
                            <label class="form-label small">
                                <p>Napíš sem, čo by si o tomto rozcestníku chcel povedať ostatným turistom — napríklad, v akom je stave, ako sa tam ide alebo čo ťa tam zaujalo. Kľudne pridaj aj osobný zážitok, pocity či krátky príbeh z miesta.</p>
                                <p>Dobre si to premysli, pretože tento formulár sa dá uložiť len raz.</p>
                            </label>
                            {{ form_widget(form.description) }}
                            {{ form_errors(form.description) }}
                        </div>

                        <div class="d-grid">
                            <button class="btn btn-primary btn-lg" type="submit">
                                Uložiť popis
                            </button>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}